{
  "name": "imap-mcp",
  "version": "1.0.0",
  "description": "IMAP Model Context Protocol server for reading, searching, and monitoring email",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ tests/ --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src/ tests/ --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathanhowell/imap-mcp.git"
  },
  "keywords": [
    "imap",
    "mcp",
    "email"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jonathanhowell/imap-mcp/issues"
  },
  "homepage": "https://github.com/jonathanhowell/imap-mcp#readme",
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "email-reply-parser": "^2.3.5",
    "html-to-text": "^9.0.5",
    "imapflow": "^1.2.13",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^22.19.15",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
